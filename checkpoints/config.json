{
  "processed_dir": "processed",
  "checkpoint_dir": "checkpoints",
  "time_window": 4,
  "snapshot_freq": "W",
  "feature_cols": [
    "LAT",
    "LON",
    "month",
    "dayofyear",
    "hour",
    "hazard_code",
    "log_exposed",
    "exposed_area",
    "rp10_risk",
    "rp100_risk",
    "mean_MNDWI",
    "mean_NDVI",
    "flood_pixel_frac",
    "lat_sin",
    "lon_sin",
    "lat_cos",
    "lon_cos",
    "month_sin",
    "month_cos",
    "day_sin",
    "day_cos",
    "node_degree",
    "node_hist_count",
    "node_hist_pos_rate",
    "rain_mean",
    "rain_max",
    "rain_sum",
    "rain_1d",
    "rain_3d",
    "rain_7d",
    "rain_30d",
    "rain_max3",
    "rain_api",
    "elev",
    "slope_deg",
    "relief"
  ],
  "gcn_hidden": 128,
  "gcn_out": 64,
  "gru_hidden": 128,
  "mlp_hidden": 64,
  "dropout": 0.3,
  "epochs": 150,
  "batch_size": 1,
  "lr": 0.002,
  "weight_decay": 0.0001,
  "pos_weight": 10.0,
  "loss_alpha": 0.4,
  "patience": 25,
  "threshold": 0.34,
  "device": "cuda",
  "shadow_mode": false
}